{% assign unlocked = shop.metafields.simpli_sections.unlocked_sections.value | default: '' %}
{% assign handle = 'pro_offer_bar' %}
{% assign is_unlocked = false %}

{% if unlocked contains handle or unlocked contains '__all_access__' %}
  {% assign is_unlocked = true %}
{% endif %}

{% style %}
.simpli-offer-wrap-{{ block.id }}{
width:100%;
margin:0;
}

.simpli-offer-bar-{{ block.id }}{
background:{{ block.settings.bg_color }};
color:{{ block.settings.text_color }};
border-radius:{{ block.settings.roundness }}px;
padding:14px 18px;
display:flex;
align-items:center;
justify-content:space-between;
gap:16px;
position:relative;
overflow:hidden;
box-shadow:0 10px 30px rgba(15,23,42,0.08);
border:1px solid rgba(255,255,255,0.08);
}

.simpli-offer-left-{{ block.id }}{
display:flex;
align-items:center;
gap:12px;
}

.simpli-offer-badge-{{ block.id }}{
background:{{ block.settings.badge_bg }};
color:{{ block.settings.badge_text }};
font-size:11px;
font-weight:700;
letter-spacing:0.08em;
text-transform:uppercase;
border-radius:999px;
padding:7px 10px;
}

.simpli-offer-heading-{{ block.id }}{
margin:0;
font-size:{{ block.settings.heading_size }}px;
font-weight:700;
}

.simpli-offer-subtext-{{ block.id }}{
margin:4px 0 0 0;
font-size:{{ block.settings.subtext_size }}px;
opacity:.88;
}

.simpli-offer-btn-{{ block.id }}{
background:{{ block.settings.button_bg }};
color:{{ block.settings.button_text_color }};
border-radius:999px;
padding:12px 16px;
font-size:14px;
font-weight:700;
text-decoration:none;
}

.simpli-locked-{{ block.id }}{
background:#fff7ed;
border:1px solid #fed7aa;
color:#9a3412;
border-radius:{{ block.settings.roundness }}px;
padding:16px;
}
{% endstyle %}

<div class="simpli-offer-wrap-{{ block.id }}" {{ block.shopify_attributes }}>
{% if is_unlocked %}

<div class="simpli-offer-bar-{{ block.id }}">

<div class="simpli-offer-left-{{ block.id }}">

{% if block.settings.badge_text_label != blank %}
<div class="simpli-offer-badge-{{ block.id }}">
{{ block.settings.badge_text_label }}
</div>
{% endif %}

<div>

<p class="simpli-offer-heading-{{ block.id }}">
{{ block.settings.heading | default:'Special offer available now' }}
</p>

{% if block.settings.subtext != blank %}
<p class="simpli-offer-subtext-{{ block.id }}">
{{ block.settings.subtext }}
</p>
{% endif %}

</div>
</div>

{% if block.settings.button_text != blank and block.settings.button_link != blank %}
<a href="{{ block.settings.button_link }}" class="simpli-offer-btn-{{ block.id }}">
{{ block.settings.button_text }}
</a>
{% endif %}

</div>

{% else %}

<div class="simpli-locked-{{ block.id }}">
<strong>Pro Offer Bar is locked</strong><br>
Unlock this section from the Simpli Sections app.
</div>

{% endif %}
</div>

{% schema %}
{
"name":"Pro Offer Bar",
"target":"section",
"settings":[
{
"type":"text",
"id":"badge_text_label",
"label":"Badge text",
"default":"LIMITED OFFER"
},
{
"type":"text",
"id":"heading",
"label":"Heading",
"default":"Extra 10% OFF on prepaid orders"
},
{
"type":"text",
"id":"subtext",
"label":"Subtext",
"default":"Use code PREPAID10 at checkout"
},
{
"type":"text",
"id":"button_text",
"label":"Button text",
"default":"Shop now"
},
{
"type":"url",
"id":"button_link",
"label":"Button link"
},
{
"type":"range",
"id":"heading_size",
"min":16,
"max":32,
"step":1,
"unit":"px",
"default":22,
"label":"Heading size"
},
{
"type":"range",
"id":"subtext_size",
"min":11,
"max":20,
"step":1,
"unit":"px",
"default":14,
"label":"Subtext size"
},
{
"type":"range",
"id":"roundness",
"min":0,
"max":30,
"step":1,
"unit":"px",
"default":18,
"label":"Roundness"
},
{
"type":"color",
"id":"bg_color",
"label":"Background color",
"default":"#111827"
},
{
"type":"color",
"id":"text_color",
"label":"Text color",
"default":"#ffffff"
},
{
"type":"color",
"id":"badge_bg",
"label":"Badge background",
"default":"#ffffff"
},
{
"type":"color",
"id":"badge_text",
"label":"Badge text color",
"default":"#111827"
},
{
"type":"color",
"id":"button_bg",
"label":"Button background",
"default":"#ffffff"
},
{
"type":"color",
"id":"button_text_color",
"label":"Button text color",
"default":"#111827"
}
]
}
{% endschema %}